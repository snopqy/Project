{
    "info": {
        "name": "SCMS API Test",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Students",
            "item": [
                {
                    "name": "Get All Students",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/api/students"
                    }
                },
                {
                    "name": "Create Student",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/api/students",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"fullname\": \"Test Student\",\n    \"email\": \"test@example.com\",\n    \"major\": \"SE\"\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "Courses",
            "item": [
                {
                    "name": "Get All Courses",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/api/courses"
                    }
                },
                {
                    "name": "Create Course",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/api/courses",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"Advanced Node.js\",\n    \"description\": \"Backend Development\",\n    \"credit\": 3\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "Enrollments",
            "item": [
                {
                    "name": "Enroll Student",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/api/enrollments",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"student_id\": 1,\n    \"course_id\": 1\n}"
                        }
                    }
                }
            ]
        }
    ]
}